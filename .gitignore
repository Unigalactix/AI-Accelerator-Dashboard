# Local runtime config — provided at deploy time from GitHub repo secrets.
.env

# Workbook snapshot — generated by the deploy workflow, not committed.
portfolio.xlsx

# Source workbook — kept out of the repo.
AI_Accelerator_Agent_Inventory_Template.xlsx

# Node / npm — transient local installs (e.g. `npm install xlsx --no-save` used for debugging)
node_modules/
package-lock.json
npm-debug.log*

# Local debug artifacts
sheet-dump.json
*.local.json

# Deployment package (generated for App Service zip deploy)
app.zip

# OS / editor cruft
.DS_Store
Thumbs.db
