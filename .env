# ============================================================
#  AI Portfolio Dashboard — data source configuration
#  Edit these values, then just refresh the browser.
# ============================================================

# The SharePoint / OneDrive link to the workbook the dashboard reads.
SHAREPOINT_URL=https://netorgft1145305-my.sharepoint.com/:x:/r/personal/venkata_kaushik_quadranttechnologies_com/_layouts/15/Doc.aspx?sourcedoc=%7B8870437F-DDDB-4027-A990-CB7AF519BFF2%7D&file=AI_Accelerator_Agent_Inventory_Template%20(1).xlsx

# The sheet/tab inside the workbook to read.
SHEET_NAME=Accelerator Inventory

# ---- Sign-in (per-user SharePoint access via Microsoft Graph) ----
# If the link above is NOT shared anonymously, users sign in with their own
# Microsoft account and their own permissions are used to read the file.
#
# To enable this, register a Microsoft Entra ID app (portal.azure.com >
# Entra ID > App registrations > New registration):
#   - Supported account types: your org (or "Any org" for multi-tenant)
#   - Platform: Single-page application (SPA)
#   - Redirect URI: the exact page URL, e.g. http://localhost:8000/AI_Portfolio_Dashboard.html
#   - API permissions (delegated, Microsoft Graph): Files.Read.All, Sites.Read.All
# Then paste the Application (client) ID below.
AAD_CLIENT_ID=

# Directory (tenant) ID, or "common" for any account / "organizations" for work accounts.
AAD_TENANT_ID=common
